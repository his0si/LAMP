# Local Python virtual environment.
# Created by tools such as python -m venv; contains installed packages and
# machine-specific interpreter paths.
.venv/

# Local Codex agent workspace metadata.
# May contain session state, tool/cache files, and local automation artifacts.
.codex/

# Local multi-agent/assistant workspace metadata.
# May contain generated task state or plugin/agent runtime files.
.agents/

__pycache__/
*.py[cod]

# Local model/data artifacts
# Original (root) location:
baseline/models/
# Per-server folders (acpl/, RT-Server/, …) — match at any depth:
**/baseline/models/
data/
outputs/
results/
runs/

# Node tooling (Claude Code 등에서 생기는 임시 파일)
node_modules/
package.json
package-lock.json

# Hugging Face / experiment caches
.cache/
wandb/
mlruns/

# OS/editor
.DS_Store
.vscode/
.idea/

.claude/
.github/